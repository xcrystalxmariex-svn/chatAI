{
  "expo": {
    "name": "AI Chat Platform",
    "slug": "chatai",
    "owner": "YOUR_EXPO_USERNAME",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aichat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aichat.platform",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Record voice messages for AI chat",
        "NSSpeechRecognitionUsageDescription": "Convert speech to text"
      }
    },
    "android": {
      "package": "com.aichat.platform",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "fa121b7f-8038-4b44-b55e-13ea16860a26"
      }
    }
  }
}
